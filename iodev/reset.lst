    36                        
    37                                        pw      132
    38                                        inclist on
    39                        
    40                                        chip    65816
    41                        
    42                        	.code
    43                        	ORG	$FFE6
    44                        
    45                        	longa	off
    46                        	longi	off
    47                        	
    48                        RESET:
    49 00:FFE6: A9 18        	lda	#$18
    50 00:FFE8: A2 02        	ldx	#$02
    51 00:FFEA: 9A           	txs			; set SP (W65C02 OPECODE)
    52 00:FFEB: 1B           	tas			; set SP (W65C816 OPECODE)
  Sun Mar 29 2026 20:38                                                                                                    Page 2


    53 00:FFEC: BA           	tsx			; SP -> X (W65C02 OPECODE)
    54 00:FFED: 8E FA FF     	stx	cpu_type
    55 00:FFF0: A9 65        	lda	#$65
    56 00:FFF2: 8D FB FF     	sta	cpu_type+1
    57                        
    58 00:FFF5: 18           	clc			; set native mode
    59 00:FFF6: FB           	xce			; if cpu=W65C02 then xce = nop operation
    60                        
    61 00:FFF7: CB           	wai	; stop CPU
    62 00:FFF8: 80 FE        aaa:	bra	aaa
    63                        
    64                        cpu_type:
    65 00:FFFA: FF FF        	dw	$ffff		; NMI
    66                        
    67 00:FFFC: E6 FF        	dw	RESET		; RESET
    68                        
    69 00:FFFE: FF FF        	dw	$ffff		; IRQ/BRK
    70                        
    71                        	END


